        sched = DictionaryClassifierGUI(self.root)
        names,file = self.get_employee_data()
        for iii in names:
            sched.update(file,iii)
            sched.process_data(7)
        


    def start(self,root):
        root.title("Main Window")
        root.geometry("400x500")  # Tall aspect ratio matching the sketch

        # Using grid weights to configure layout behavior
        root.grid_columnconfigure(0, weight=1)
        root.grid_columnconfigure(1, weight=1)

        # Row 0: Button A (Left) and Button B (Right)
        btn_a = tk.Button(root, text="Populate employee", command=self.get_cards, padx=10, pady=5)
        btn_a.grid(row=0, column=0, padx=20, pady=(30, 20), sticky="w")

        btn_b = tk.Button(root, text="Make employee schedule", command=self.assign_schedule, padx=10, pady=5)
        btn_b.grid(row=0, column=1, padx=20, pady=(30, 20), sticky="e")

        # Row 1: Button C (Centered below A and B)
        btn_c = tk.Button(root, text="Check on employee", command=self.check_on_schedule, padx=15, pady=5)
        # columnspan=2 allows it to center across the entire window width
        btn_c.grid(row=1, column=0, columnspan=2, pady=20)
