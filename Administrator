import tkinter as tk
from tkinter import simpledialog, messagebox, filedialog
import pandas as pd
import random

# --- Functions called by the buttons ---
class Administrator:

    def __init__(self,root):

        self.root = root
        self.start(root)

    def get_employee_data(self):
        # Fallback to None if self.root doesn't exist or is destroyed
        parent_win = self.root if (hasattr(self, 'root') and self.root.winfo_exists()) else None

        # 1. Ask for the total number of employees
        num_employees = simpledialog.askinteger(
            "Employee Count",
            "How many employees do you have?",
            minvalue=1,
            parent=parent_win
        )

        if not num_employees:
            messagebox.showinfo("Cancelled", "No employee count provided.")
            return

        employee_list = []

        # 2. Loop and prompt for each employee's name
        for i in range(num_employees):
            name = simpledialog.askstring(
                "Employee Name",
                f"Enter the name for employee #{i + 1}:",
                parent=parent_win
            )

            if name is None:  # User pressed cancel midway
                messagebox.showwarning("Incomplete", "Process interrupted. Keeping partial list.")
                break

            if name.strip():
                employee_list.append(name.strip())
            else:
                employee_list.append(f"Employee {i + 1}")

        # 3. The Last Question: Ask where to save the file
        file_path = "C:\\Users"
        if employee_list:
            file_path = filedialog.asksaveasfilename(
                title="Select File Location to Save Employees",
                parent=parent_win,
                defaultextension=".txt",
                filetypes=[("Text Files", "*.txt"), ("CSV Files", "*.csv"), ("All Files", "*.*")]
            )

        return employee_list,file_path


    def get_cards(self):
        # Create a new top-level window
        window_a = tk.Toplevel(root)
        window_a.title("Get Cards")
        window_a.geometry("300x200")
        g = self.generate_cards()
        for index, (key, value) in enumerate(g.items()):
            # key label (Bolded, aligned left)
            lbl_key = tk.Label(window_a, text=f"{key}:", font=("Arial", 10,'bold'))
            lbl_key.grid(row=index,column=0,padx=10,pady=5,sticky="w")

            #value label
            lbl_key = tk.Label(window_a, text=value, font=("Arial", 10))
            lbl_key.grid(row=index, column=1, padx=10, pady=5, sticky="w")

    def generate_cards(self):

        suit = ('h','d','c','s')
        cards = ('A','K','Q','J','10','9','8','7','6','5','4','3','2')
        deck = {}
        for i in suit:
            deck[i] = []
            for ii in cards:
                deck[i].append(i+ii)
        players = {}
        for i in range(4):
            players[i] = []
            for ii in range(5):
                deck,s = self.get_card(deck,suit)
                players[i].append(s)
        return self.drop_card(players)


    def drop_card(self,players):

        for i in players:
            players[i].remove(random.choice(players[i]))

        return players


    def get_card(self,deck,suit):

        ss = suit[random.randint(0,random.randint(0,len(suit)-1))]
        b = random.randint(0,random.randint(0,len(deck[ss])-1))

        c = deck[ss][b]

        deck[ss].remove(deck[ss][b])

        return deck,c


